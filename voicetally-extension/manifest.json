{
  "manifest_version": 3,
  "name": "VoiceTally",
  "version": "0.1.0",
  "description": "Secure business query assistant.",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ask VoiceTally",
    "default_icon": "images/voice_tally.png"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "host_permissions": [
    "http://127.0.0.1:3000/*"
  ],
  "permissions": [
    "sidePanel",
    "storage",
    "tabs"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q",
        "mac": "Command+Shift+Q"
      },
      "description": "Open VoiceTally Popup"
    }
  }
}