# ─── VoiceTally Intelligence Service (FastAPI — port 8001) ───────────────────

# App settings
APP_NAME=VoiceTally Intelligence Service
APP_VERSION=1.0.0
DEBUG=True

# STT Provider: "whisper" (local) or "openai"
STT_PROVIDER=whisper

# OpenAI API key — only required if using LLM-based intent classification or summarization
# OPENAI_API_KEY=sk-...


# ─── VoiceTally Backend (Node.js — port 3000) ────────────────────────────────

# Server
PORT=3000
HOST=127.0.0.1

# Rate limiting
RATE_LIMIT_WINDOW_MIN=1
RATE_LIMIT_MAX_REQ=100

# JWT Secret — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_here

# Chrome Extension ID — from chrome://extensions after loading the extension
EXTENSION_ID=your_chrome_extension_id_here

# Tally data CSV path (relative to voicetally-backend/)
DATA_FILE_PATH=data/sales.csv
